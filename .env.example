# ============================================================
# FloXer — Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local development.
# For Render: set these in the dashboard under Environment.
# Never commit .env or .env.local to git.
# ============================================================


# --- App ---
APP_ENV=production                        # use "development" locally
PORT=5000                                 # Render sets this automatically
# --- Flask ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=<long-random-string-min-32-chars>
# --- Xero OAuth ---
# From developer.xero.com → your app → OAuth credentials
XERO_CLIENT_ID=<your-xero-client-id>
XERO_CLIENT_SECRET=<your-xero-client-secret>
XERO_REDIRECT_URI=https://<your-render-app>.onrender.com/callback
XERO_SCOPES=accounting.transactions accounting.contacts accounting.settings accounting.journals.read offline_access

# Optional: pin a specific Xero org (tenant) instead of letting user pick.
# A Xero account can be connected to multiple organisations (e.g. a business owner
# with multiple companies, or an accountant managing several clients). When this is
# unset, the app uses the most recently connected org, or prompts the user to pick
# via /connections. Set this to skip that selection entirely — useful for a
# single-user deployment where there is only ever one organisation.
# To find your tenant ID: connect Xero, then visit /connections in the app.
# XERO_TENANT_ID=<xero-tenant-uuid>

# --- Supabase ---
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# From Supabase dashboard → Project Settings → Database → Connection string (pooler)
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=require

# --- Optional: Rate limiting ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120


# --- Optional: Tax frequency overrides ---
# FloXer auto-detects GST and PAYG lodgement frequency from Xero transaction history.
# Super defaults to quarterly. These vars let you override the detected values if
# auto-detection is wrong (e.g. new Xero file, recently changed lodgement frequency,
# or sparse history). Leave commented out unless the detected frequency is incorrect.
#
# GST_FREQUENCY=quarterly       # monthly or quarterly
# PAYG_FREQUENCY=quarterly      # monthly or quarterly
# SUPER_FREQUENCY=quarterly     # monthly or quarterly
# PAYG_MONTHLY_DUE_DAY=21       # day of month PAYG is due when frequency is monthly
