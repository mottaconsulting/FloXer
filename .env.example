# ============================================================
# FloXer — Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local development.
# For Render: set these in the dashboard under Environment.
# Never commit .env or .env.local to git.
# ============================================================


# --- App ---
APP_ENV=production                        # use "development" locally
PORT=5000                                 # Render sets this automatically

# --- Flask ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=<long-random-string-min-32-chars>


# --- Xero OAuth ---
# From developer.xero.com → your app → OAuth credentials
XERO_CLIENT_ID=<your-xero-client-id>
XERO_CLIENT_SECRET=<your-xero-client-secret>
XERO_REDIRECT_URI=https://<your-render-app>.onrender.com/callback
XERO_SCOPES=accounting.transactions accounting.contacts accounting.settings accounting.journals.read offline_access

# Optional: pin a specific Xero org (tenant) instead of letting user pick
# XERO_TENANT_ID=<xero-tenant-uuid>

# Optional: identify your primary bank account for live balance
# XERO_PRIMARY_BANK_ACCOUNT_CODE=1200
# XERO_PRIMARY_BANK_ACCOUNT_NAME=business cheque account
# XERO_PRIMARY_BANK_ACCOUNT_NUMBER=


# --- Supabase ---
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# From Supabase dashboard → Project Settings → Database → Connection string (pooler)
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=require


# --- Optional: Security ---
ALLOWED_ORIGINS=https://<your-render-app>.onrender.com
CSP_EXTRA_CONNECT_SRC=
CSP_EXTRA_SCRIPT_SRC=https://cdn.jsdelivr.net
CSP_EXTRA_STYLE_SRC=https://fonts.googleapis.com
CSP_EXTRA_FONT_SRC=https://fonts.gstatic.com


# --- Optional: Rate limiting ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120


# --- Optional: Liability due-date rules ---
GST_FREQUENCY=monthly         # monthly or quarterly
PAYG_FREQUENCY=monthly        # monthly or quarterly
SUPER_FREQUENCY=quarterly     # monthly or quarterly
PAYG_MONTHLY_DUE_DAY=21
